@startuml dev-tooling
!theme plain
skinparam backgroundColor #1e1e2e
skinparam defaultFontColor #cdd6f4
skinparam arrowColor #94e2d5
skinparam borderColor #45475a
skinparam shadowing false

skinparam rectangle {
  BackgroundColor #181825
  BorderColor #45475a
  FontColor #cdd6f4
}
skinparam package {
  BackgroundColor #1e1e2e
  BorderColor #45475a
  FontColor #94e2d5
}

package "home/tco/home.nix" {
  rectangle "Rust toolchain\n(rust-overlay: nightly + stable\nrust-analyzer, cargo)" as rust
  rectangle "Python 3.13\n(pip, black, isort\naider-chat)" as python
  rectangle "Web\n(Node.js 22, TypeScript\npnpm, yarn, Tailwind LSP)" as web
  rectangle "Editors\n(Doom Emacs daemon\nNeovim, VSCode, Zed)" as editors
  rectangle "AI / LLM\n(Ollama CUDA\naider-chat, LM Studio)" as ai
}

package "home/tco/modules/apps/" {
  rectangle "cad.nix\nKiCad, FreeCAD\nObsidian" as cad
  rectangle "embedded.nix\nArduino IDE/CLI\nesptool, minicom" as emb
  rectangle "data.nix\nDBeaver, Grafana\nInfluxDB2" as data
}

rectangle "direnv + nix-direnv\n(per-project environments)" as direnv

rust -[hidden]-> python
python -[hidden]-> web
web -[hidden]-> editors
editors -[hidden]-> ai
cad -[hidden]-> emb
emb -[hidden]-> data
"home/tco/home.nix" --> direnv

@enduml
