@startuml
title Theme propagation (Seaglass)

skinparam backgroundColor #E8E8E8

rectangle "Theme" {
  [Seaglass theme\n#94E2D5] as theme
}

rectangle "Config layer" {
  [Hyprland\nseaglass.conf\ntokens.conf] as hypr
  [Waybar\nmocha.css\nstyle.css] as waybar
  [Rofi\ncolumn-tco.rasi] as rofi
}

rectangle "Rendering" {
  [Foot\nfoot.ini] as foot
  [Hyprchroma fork\nhypr-darkwindow] as hyprchroma
  [Hyprspace\noverview] as hyprspace
  [GTK / Icons\nAdwaita-dark\nPapirus-Dark] as gtk
}

theme --> hypr
theme --> waybar
theme --> rofi
hypr --> foot
hypr --> hyprchroma
hypr --> hyprspace
rofi --> gtk

@enduml
