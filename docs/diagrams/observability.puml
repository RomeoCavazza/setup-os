@startuml
!theme plain
skinparam backgroundColor #0f172a
skinparam defaultFontColor #e2e8f0
skinparam arrowColor #94e2d5
skinparam borderColor #475569
skinparam shadowing false

skinparam rectangle {
  BackgroundColor #1e293b
  BorderColor #475569
  FontColor #e2e8f0
}
skinparam package {
  BackgroundColor #0f172a
  BorderColor #475569
  FontColor #94e2d5
}
skinparam note {
  BackgroundColor #1e293b
  BorderColor #94e2d5
  FontColor #e2e8f0
}

package "Host Metrics & Logs" {
  rectangle "nix-metrics\n(textfile collector)" as nix_metrics
  rectangle "journald" as journald
}

package "Observability Core" {
  rectangle "node_exporter" as node_exporter
  rectangle "Prometheus" as prometheus
  rectangle "Promtail" as promtail
  rectangle "Loki" as loki
  rectangle "Grafana\n(3 dashboards)" as grafana
}

package "Continuous Documentation" {
  rectangle "grafana-snapshot-sync\n(systemd timer)" as snapshot
  rectangle "docs/assets/live/*.png" as pngs
  rectangle "setup-os repo" as repo
  rectangle "docs/wiki\n(tracked docs)" as wiki
}

nix_metrics --> node_exporter

node_exporter --> prometheus

prometheus --> grafana

note right of grafana
PromQL
Scrape :9100
end note

journald --> promtail

promtail --> loki

loki --> grafana

note right of loki
LogQL
journal tail
push logs
end note

grafana --> snapshot

snapshot --> pngs

pngs --> repo

repo --> wiki

note right of snapshot
headless capture via /d/{uid}/{slug}?kiosk
write if delta > 0.5%
publish clone add/commit/push
docs/wiki sync flow
end note

note bottom of promtail
labels injected:
component=display|build|system
end note

@enduml
