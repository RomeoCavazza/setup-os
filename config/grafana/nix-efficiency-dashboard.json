{
  "title": "Nix Efficiency",
  "uid": "nix-efficiency",
  "schemaVersion": 38,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "type": "gauge",
      "title": "Generation Debt",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_generations_count", "legendFormat": "retained generations", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 40,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "type": "gauge",
      "title": "Freshness Index (days)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_flake_lock_age_seconds / 86400", "legendFormat": "days", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "min": 0,
          "max": 45,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "type": "timeseries",
      "title": "Closure Size vs Closure Paths",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "nix_closure_bytes", "legendFormat": "closure bytes", "refId": "A" },
        { "expr": "nix_closure_paths", "legendFormat": "closure paths", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [
        {
          "matcher": { "id": "byName", "options": "closure paths" },
          "properties": [{ "id": "unit", "value": "none" }]
        }
      ] }
    },
    {
      "id": 4,
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Store vs Closure Bytes",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "nix_store_bytes", "legendFormat": "store", "refId": "A" },
        { "expr": "nix_closure_bytes", "legendFormat": "closure", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "id": 5,
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Store Overhead Paths",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "nix_store_paths - nix_closure_paths", "legendFormat": "overhead paths", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 6,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "type": "timeseries",
      "title": "Rebuild Duration Trend",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "nix_rebuild_duration_ms / 1000", "legendFormat": "duration s", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
