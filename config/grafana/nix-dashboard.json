{
  "title": "NixOS Metrics",
  "uid": "nixos-metrics",
  "schemaVersion": 38,
  "refresh": "30s",
  "description": "Live health view for Nix pressure, rebuild cost, and store growth.",
  "panels": [
    {
      "id": 0,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "type": "text",
      "title": "Live system state",
      "transparent": true,
      "options": {
        "mode": "markdown",
        "content": "**Read this dashboard left to right:** pressure now, retained state, then trends. It is refreshed live by Grafana and the PNG snapshot pipeline only mirrors the current state.",
        "contentType": "markdown"
      }
    },
    {
      "id": 1,
      "gridPos": { "x": 0, "y": 3, "w": 8, "h": 5 },
      "type": "gauge",
      "title": "CPU Pressure",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_pressure_cpu_avg10", "legendFormat": "cpu", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "gridPos": { "x": 8, "y": 3, "w": 8, "h": 5 },
      "type": "gauge",
      "title": "IO Pressure",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_pressure_io_some_avg10", "legendFormat": "io", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "gridPos": { "x": 16, "y": 3, "w": 8, "h": 5 },
      "type": "gauge",
      "title": "RAM Pressure",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_pressure_mem_some_avg10", "legendFormat": "mem", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 4 },
      "type": "stat",
      "title": "Generation",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_generation", "legendFormat": "gen", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 4 },
      "type": "stat",
      "title": "Store Size",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_store_bytes", "legendFormat": "store", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "id": 6,
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 4 },
      "type": "stat",
      "title": "Closure Size",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_closure_bytes", "legendFormat": "closure", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "id": 9,
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "type": "timeseries",
      "title": "Nix Store Size over Time",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "nix_store_bytes", "legendFormat": "total store", "refId": "A" },
        { "expr": "nix_closure_bytes", "legendFormat": "current closure", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "id": 11,
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "type": "timeseries",
      "title": "Rebuild Duration",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_rebuild_duration_ms / 1000", "legendFormat": "duration (s)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
