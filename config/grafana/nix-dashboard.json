{
  "title": "NixOS Metrics",
  "uid": "nixos-metrics",
  "schemaVersion": 38,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "type": "gauge",
      "title": "CPU Pressure",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_pressure_cpu_avg10", "legendFormat": "cpu", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "type": "gauge",
      "title": "IO Pressure",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_pressure_io_some_avg10", "legendFormat": "io", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "type": "gauge",
      "title": "RAM Pressure",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_pressure_mem_some_avg10", "legendFormat": "mem", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "gridPos": { "x": 0, "y": 4, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Generation",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_generation", "legendFormat": "gen", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "gridPos": { "x": 4, "y": 4, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Store Size",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_store_bytes", "legendFormat": "store", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "id": 6,
      "gridPos": { "x": 8, "y": 4, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Closure Size",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_closure_bytes", "legendFormat": "closure", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "id": 7,
      "gridPos": { "x": 12, "y": 4, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Closure Paths",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_closure_paths", "legendFormat": "paths", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8,
      "gridPos": { "x": 16, "y": 4, "w": 4, "h": 4 },
      "type": "stat",
      "title": "flake.lock age (days)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_flake_lock_age_seconds / 86400", "legendFormat": "days", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 14 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 9,
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Nix Store Size over Time",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "nix_store_bytes", "legendFormat": "total store", "refId": "A" },
        { "expr": "nix_closure_bytes", "legendFormat": "current closure", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "id": 10,
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Store Overhead (paths outside current closure)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_store_paths - nix_closure_paths", "legendFormat": "orphaned paths", "refId": "A" }]
    },
    {
      "id": 11,
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Rebuild Duration",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_rebuild_duration_ms / 1000", "legendFormat": "duration (s)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 12,
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "flake.lock Age",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_flake_lock_age_seconds / 86400", "legendFormat": "days since update", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "d" } }
    }
  ]
}
