{
  "title": "Incident Correlation",
  "uid": "incident-correlation",
  "schemaVersion": 38,
  "refresh": "30s",
  "description": "High-frequency pressure timeline linked to Loki logs for incident analysis.",
  "panels": [
    {
      "id": 0,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "type": "text",
      "title": "Incident context",
      "transparent": true,
      "options": {
        "mode": "markdown",
        "content": "**This dashboard is for correlation, not overview.** Start with pressure, then move immediately to the log panel when something spikes.",
        "contentType": "markdown"
      }
    },
    {
      "id": 1,
      "gridPos": { "x": 0, "y": 3, "w": 8, "h": 5 },
      "type": "gauge",
      "title": "CPU Pressure",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_pressure_cpu_avg10", "legendFormat": "cpu", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "gridPos": { "x": 8, "y": 3, "w": 8, "h": 5 },
      "type": "gauge",
      "title": "IO Pressure",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_pressure_io_some_avg10", "legendFormat": "io", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "gridPos": { "x": 16, "y": 3, "w": 8, "h": 5 },
      "type": "gauge",
      "title": "Memory Pressure",
      "datasource": "Prometheus",
      "targets": [{ "expr": "nix_pressure_mem_some_avg10", "legendFormat": "mem", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "type": "timeseries",
      "title": "Pressure Timeline",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "nix_pressure_cpu_avg10", "legendFormat": "CPU", "refId": "A" },
        { "expr": "nix_pressure_io_some_avg10", "legendFormat": "IO", "refId": "B" },
        { "expr": "nix_pressure_mem_some_avg10", "legendFormat": "MEM", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 5,
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "type": "logs",
      "title": "Loki Journal (component filter)",
      "datasource": "Loki",
      "targets": [
        { "expr": "{job=\"systemd-journal\",component=~\"display|build\"}", "refId": "A" }
      ],
      "options": { "showTime": true, "sortOrder": "Descending" }
    }
  ]
}
