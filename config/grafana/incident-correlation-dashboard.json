  "panels": [
    {
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "options": {
        "content": "**This dashboard is for correlation, not overview.** Start with pressure, then move immediately to logs when something spikes.",
        "contentType": "markdown",
        "mode": "markdown"
      },
      "title": "Incident context",
      "transparent": true,
      "type": "text"
    },
    {
      "collapsed": false,
