{
  "custom/nixos": {
    "format": "’īō",
    "on-click": "wofi --show drun",
    "tooltip": true,
    "tooltip-format": "NixOS"
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip": true,
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "waybar"
    ],
    "app_ids-mapping": {
      "firefox": "firefox",
      "org.gnome.Nautilus": "org.gnome.Nautilus"
    }
  },
  "custom/cava_mviz": {
    "exec": "$HOME/.config/waybar/WaybarCava.sh",
    "format": "{}"
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "active-only": false,
    "format": "{icon}",
    "on-click": "hyprctl dispatch workspace {id}",
    "format-icons": {
      "1": "’äī",
      "2": "’äī",
      "3": "’äī",
      "4": "’äī",
      "5": "’äī",
      "urgent": "’ü¬",
      "active": "’äæ",
      "default": "’äī"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "cpu": {
    "format": "’ŗø  {usage}%",
    "tooltip": true,
    "on-click": "kitty htop &"
  },
  "memory": {
    "format": "’āē  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
    "critical-threshold": 100,
    "format-critical": "’ŗć {temperatureC}",
    "format": "’ŗē {temperatureC}┬░C"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 20
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "’Ś¦  {capacity}%",
    "format-plugged": "’ć”  {capacity}%",
    "format-icons": [
      "’ēä",
      "’ēā",
      "’ēé",
      "’ēü",
      "’ēĆ"
    ]
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "’Ü®",
    "format-icons": {
      "headphone": "’Ćź",
      "hands-free": "’¢É",
      "headset": "’¢É",
      "phone": "’éĢ",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": [
        "’Ć”",
        "’Ć¦",
        "’Ć©"
      ]
    },
    "on-click": "pavucontrol"
  },
  "network#speed": {
    "interval": 1,
    "format-wifi": "¾░ż©  ’ä╣ {bandwidthUpBytes} ’ä║ {bandwidthDownBytes}",
    "format-ethernet": "¾░īś  ’ä╣ {bandwidthUpBytes} ’ä║ {bandwidthDownBytes}",
    "format-disconnected": "¾░īÖ",
    "tooltip-format": "{ipaddr}",
    "min-length": 24,
    "max-length": 24
  },
  "bluetooth": {
    "format": "’Ŗō",
    "format-disabled": "¾░é│",
    "format-connected": "¾░é▒ {num_connections}",
    "tooltip": true
  },
  "tray": {
    "icon-size": 20,
    "spacing": 6
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%d-%m-%Y}"
  },
  "mpris": {
    "interval": 10,
    "format": "{player_icon}",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "on-click-middle": "playerctl play-pause",
    "on-click": "playerctl previous",
    "on-click-right": "playerctl next",
    "scroll-step": 5.0,
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "player-icons": {
      "chromium": "’ē©",
      "default": "’ĆØ",
      "firefox": "’ē®",
      "spotify": "’å╝",
      "vlc": "¾░Ģ╝"
    },
    "status-icons": {
      "paused": "¾░ÉÄ",
      "playing": "’üŗ",
      "stopped": "’üŹ"
    },
    "max-length": 30
  }
}