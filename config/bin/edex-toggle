#!/usr/bin/env bash
set -euo pipefail

LOG=/tmp/edex.bind.log
OUT=/tmp/edex.out

ts() { date --iso-8601=seconds; }
log() { echo "$(ts) $*" >>"$LOG"; }

log "edex-toggle called; UID=$(id -u); USER=$USER; DISPLAY=${DISPLAY-}; WAYLAND_DISPLAY=${WAYLAND_DISPLAY-}; XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR-}"

# toggle off
if systemctl --user --quiet is-active edex-ui.scope 2>/dev/null; then
  systemctl --user stop edex-ui.scope || true
  log "stopped edex-ui.scope"
  exit 0
fi

rm -f "$OUT"

# 1) essai normal (XWayland)
systemd-run --user --unit=edex-ui --collect --scope \
  --working-directory="$HOME" \
  --setenv=DISPLAY="${DISPLAY:-:0}" \
  --setenv=XDG_SESSION_TYPE=x11 \
  --setenv=ELECTRON_ENABLE_WAYLAND=0 \
  --setenv=NIXOS_OZONE_WL=0 \
  --setenv=ELECTRON_OZONE_PLATFORM_HINT=x11 \
  /run/current-system/sw/bin/bash -lc '
    exec env -u WAYLAND_DISPLAY \
      edex-ui \
        --no-sandbox --disable-gpu-sandbox \
        --enable-logging=stderr --v=1 \
      >>/tmp/edex.out 2>&1
  '

log "started edex-ui.scope"
