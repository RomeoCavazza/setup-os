#!/usr/bin/env bash
set -euo pipefail

export LD_LIBRARY_PATH="/run/opengl-driver/lib:/run/current-system/sw/lib:${LD_LIBRARY_PATH:-}"
export NIX_LD_LIBRARY_PATH="/run/opengl-driver/lib:/run/current-system/sw/lib:${NIX_LD_LIBRARY_PATH:-}"

export NIX_SSL_CERT_FILE=/etc/ssl/certs/ca-bundle.crt
export SSL_CERT_FILE=/etc/ssl/certs/ca-bundle.crt

# --- Browser Shim ---
export NIXOS_XDG_OPEN_USE_PORTAL=0
export BROWSER=firefox
SHIM_DIR="$HOME/.cache/antigravity-shim"
mkdir -p "$SHIM_DIR"
cat > "$SHIM_DIR/xdg-open" << 'SH'
#!/usr/bin/env bash
exec firefox "$@"
SH
chmod +x "$SHIM_DIR/xdg-open"
export PATH="$SHIM_DIR:$PATH"

BIN_TAR="$HOME/.local/opt/antigravity-ide/Antigravity IDE/antigravity-ide"
if [ -f "$BIN_TAR" ]; then
  chmod +x "$BIN_TAR" 2>/dev/null || true
  exec "$BIN_TAR" --password-store="basic" "$@"
fi
echo "Antigravity IDE introuvable: $BIN_TAR" >&2
exit 1
