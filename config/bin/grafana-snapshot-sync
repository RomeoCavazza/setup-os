#!/usr/bin/env bash
# Render Grafana dashboards to PNG and push only meaningful visual updates.

set -euo pipefail

REPO_DIR="/etc/nixos"
OUT_DIR="${REPO_DIR}/docs/assets/live"
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

GRAFANA_URL="${GRAFANA_URL:-http://127.0.0.1:3000}"
SINCE="${SINCE:-now-6h}"
UNTIL="${UNTIL:-now}"
MIN_CHANGE_PERCENT="${MIN_CHANGE_PERCENT:-5}"
SNAPSHOT_GIT_NAME="${SNAPSHOT_GIT_NAME:-setup-os bot}"
SNAPSHOT_GIT_EMAIL="${SNAPSHOT_GIT_EMAIL:-bot@setup-os.local}"
BROWSER_BIN="${BROWSER_BIN:-/run/current-system/sw/bin/google-chrome}"

# uid:slug:file
DASHBOARDS=(
  "nixos-metrics:nixos-metrics:live-dashboard.png"
  "nix-efficiency:nix-efficiency:nix-efficiency.png"
  "incident-correlation:incident-correlation:incident-dashboard.png"
)

mkdir -p "$OUT_DIR"

for _ in $(seq 1 30); do
  if curl -fsS "${GRAFANA_URL}/api/health" >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

if ! curl -fsS "${GRAFANA_URL}/api/health" >/dev/null 2>&1; then
  echo "snapshot-sync: grafana is not reachable at ${GRAFANA_URL}" >&2
  exit 1
fi

if [[ ! -x "$BROWSER_BIN" ]]; then
  echo "snapshot-sync: browser binary not executable: $BROWSER_BIN" >&2
  exit 1
fi

has_changes=0

for item in "${DASHBOARDS[@]}"; do
  IFS=":" read -r uid slug filename <<< "$item"
  new_file="${TMP_DIR}/${filename}"
  target_file="${OUT_DIR}/${filename}"

  dashboard_url="${GRAFANA_URL}/d/${uid}/${slug}?orgId=1&from=${SINCE}&to=${UNTIL}&kiosk"
  "$BROWSER_BIN" \
    --headless \
    --disable-gpu \
    --no-sandbox \
    --hide-scrollbars \
    --window-size=2200,1200 \
    --virtual-time-budget=15000 \
    --screenshot="$new_file" \
    "$dashboard_url" >/dev/null 2>&1

  if [[ ! -f "$target_file" ]]; then
    mv "$new_file" "$target_file"
    has_changes=1
    continue
  fi

  changed_pixels=$(compare -metric AE "$target_file" "$new_file" null: 2>&1 || true)
  total_pixels=$(identify -format "%[fx:w*h]" "$target_file")
  percent_changed=$(awk -v c="$changed_pixels" -v t="$total_pixels" 'BEGIN { if (t == 0) print 100; else printf "%.2f", (c * 100) / t }')

  if awk -v p="$percent_changed" -v m="$MIN_CHANGE_PERCENT" 'BEGIN { exit !(p > m) }'; then
    mv "$new_file" "$target_file"
    has_changes=1
  fi
done

if [[ "$has_changes" -eq 0 ]]; then
  exit 0
fi

cd "$REPO_DIR"

if [[ ! -w .git/index ]]; then
  echo "snapshot-sync: repository is not writable by current user" >&2
  exit 1
fi

if ! git config user.name >/dev/null; then
  git config user.name "$SNAPSHOT_GIT_NAME"
fi

if ! git config user.email >/dev/null; then
  git config user.email "$SNAPSHOT_GIT_EMAIL"
fi

git add docs/assets/live/*.png

if git diff --cached --quiet; then
  exit 0
fi

git commit -m "docs(live): refresh Grafana snapshots"
git push
