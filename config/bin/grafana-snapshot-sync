#!/usr/bin/env bash
# Render Grafana dashboards to PNG and push only meaningful visual updates.

set -euo pipefail

REPO_DIR="/etc/nixos"
OUT_DIR="${REPO_DIR}/docs/assets/live"
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

GRAFANA_URL="${GRAFANA_URL:-http://localhost:3001}"
SINCE="${SINCE:-now-6h}"
UNTIL="${UNTIL:-now}"
MIN_CHANGE_PERCENT="${MIN_CHANGE_PERCENT:-0.3}"
SNAPSHOT_GIT_NAME="${SNAPSHOT_GIT_NAME:-setup-os bot}"
SNAPSHOT_GIT_EMAIL="${SNAPSHOT_GIT_EMAIL:-bot@setup-os.local}"
PLAYWRIGHT_CORE_PATH="${PLAYWRIGHT_CORE_PATH:-}"
CHROME_BIN="${CHROME_BIN:-/run/current-system/sw/bin/google-chrome}"

# uid:slug:file
DASHBOARDS=(
  "nixos-metrics:nixos-metrics:live-dashboard.png"
  "nix-efficiency:nix-efficiency:nix-efficiency.png"
  "incident-correlation:incident-correlation:incident-dashboard.png"
  "nixos-compiled:nixos-system-overview:nixos-system-overview.png"
)

mkdir -p "$OUT_DIR"

for _ in $(seq 1 30); do
  if curl -fsS "${GRAFANA_URL}/api/health" >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

if ! curl -fsS "${GRAFANA_URL}/api/health" >/dev/null 2>&1; then
  echo "snapshot-sync: grafana is not reachable at ${GRAFANA_URL}" >&2
  exit 1
fi

has_changes=0

for item in "${DASHBOARDS[@]}"; do
  IFS=":" read -r uid slug filename <<< "$item"
  new_file="${TMP_DIR}/${filename}"
  target_file="${OUT_DIR}/${filename}"

  dashboard_url="${GRAFANA_URL}/d/${uid}/${slug}?orgId=1&from=${SINCE}&to=${UNTIL}&kiosk"
  if [[ -z "$PLAYWRIGHT_CORE_PATH" ]] && [[ -f $(nix-build --no-out-link "<nixpkgs>" -A playwright-driver 2>/dev/null)/index.js ]]; then PLAYWRIGHT_CORE_PATH=$(nix-build --no-out-link "<nixpkgs>" -A playwright-driver)/index.js; fi
  if [[ -z "$PLAYWRIGHT_CORE_PATH" ]]; then
    echo "snapshot-sync: PLAYWRIGHT_CORE_PATH is not set" >&2
    exit 1
  fi

  PLAYWRIGHT_CORE_PATH="$PLAYWRIGHT_CORE_PATH" \
  CHROME_BIN="$CHROME_BIN" \
  DASHBOARD_URL="$dashboard_url" \
  OUTPUT_FILE="$new_file" \
  node <<'NODE'
const { chromium } = require(process.env.PLAYWRIGHT_CORE_PATH);

(async () => {
  const browser = await chromium.launch({
    executablePath: process.env.CHROME_BIN,
    headless: true,
    args: ['--no-sandbox', '--disable-setuid-sandbox', '--font-render-hinting=none'],
  });

  const page = await browser.newPage({ 
    viewport: { width: 1920, height: 3000 },
    deviceScaleFactor: 2, // Better resolution for documentation
  });
  
  page.on('console', msg => console.log(`snapshot-sync: browser: ${msg.text()}`));


  console.log(`snapshot-sync: navigating to ${process.env.DASHBOARD_URL}`);
  try {
    await page.goto(process.env.DASHBOARD_URL, { waitUntil: 'load', timeout: 60000 });
    
    // Wait for network to settle
    await page.waitForLoadState('networkidle', { timeout: 30000 }).catch(() => console.log('snapshot-sync: networkidle timeout, proceeding anyway'));

    // Wait for any element that looks like a panel or dashboard
    await page.waitForSelector('.panel-title, .panel-title-text, [data-testid="panel-header"]', { timeout: 15000 })
      .catch(() => console.log('snapshot-sync: panel title not found, checking body...'));

    // Give extra time for ECharts and data fetching
    console.log(`snapshot-sync: waiting for stabilization...`);
    await page.waitForTimeout(10000); 

    // Calculate the bounding box of the actual content to remove the "cushion of air"
    const clip = await page.evaluate(() => {
      // Find all grid items and specific panel containers
      const items = Array.from(document.querySelectorAll('.react-grid-item, .panel-container, [data-testid="grid-item"]'));
      
      const visibleItems = items.filter(p => {
        const rect = p.getBoundingClientRect();
        // Ignore tiny, invisible, or clearly out-of-bounds items
        const isVisible = rect.height > 20 && rect.width > 20;
        const isWithinReason = rect.bottom < 5000;
        return isVisible && isWithinReason;
      });
      
      let maxBottom = 0;
      visibleItems.forEach((p) => {
        const rect = p.getBoundingClientRect();
        if (rect.bottom > maxBottom) maxBottom = rect.bottom;
      });
      
      // If we still get zero, fallback to a sensible default
      // Otherwise, add a small 20px padding
      const height = maxBottom > 100 ? Math.ceil(maxBottom) + 20 : 1200;
      
      return { x: 0, y: 0, width: 1920, height };
    });

    console.log(`snapshot-sync: cropping to height ${clip.height}px`);
    await page.screenshot({ path: process.env.OUTPUT_FILE, clip });
    console.log(`snapshot-sync: ${process.env.OUTPUT_FILE} captured`);
  } catch (e) {
    console.error(`snapshot-sync: rendering failed: ${e.message}`);
    process.exit(1);
  }
  await browser.close();
})().catch((error) => {
  console.error(`snapshot-sync: fatal error: ${error.message}`);
  process.exit(1);
});
NODE

  if [[ ! -f "$target_file" ]]; then
    mv "$new_file" "$target_file"
    has_changes=1
    continue
  fi

  changed_pixels=$(compare -metric AE "$target_file" "$new_file" null: 2>&1 || true)
  total_pixels=$(identify -format "%[fx:w*h]" "$target_file")
  percent_changed=$(awk -v c="$changed_pixels" -v t="$total_pixels" 'BEGIN { if (t == 0) print 100; else printf "%.2f", (c * 100) / t }')

  if awk -v p="$percent_changed" -v m="$MIN_CHANGE_PERCENT" 'BEGIN { exit !(p > m) }'; then
    mv "$new_file" "$target_file"
    has_changes=1
  fi
done

if [[ "$has_changes" -eq 0 ]]; then
  exit 0
fi

cd "$REPO_DIR"

if [[ ! -w .git/index ]]; then
  echo "snapshot-sync: repository is not writable by current user" >&2
  exit 1
fi

if ! git config user.name >/dev/null; then
  git config user.name "$SNAPSHOT_GIT_NAME"
fi

if ! git config user.email >/dev/null; then
  git config user.email "$SNAPSHOT_GIT_EMAIL"
fi

git add docs/assets/live/*.png

if git diff --cached --quiet; then
  exit 0
fi

git commit -m "docs(live): refresh Grafana snapshots"
git push
