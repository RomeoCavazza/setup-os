#!/usr/bin/env bash
# Wrapper around nixos-rebuild that records build duration, exit status,
# and timestamp to the Prometheus textfile collector.
#
# Usage: rebuild [--dev] [--pull] [--allow-dirty] <switch|boot|test|dry-activate|build> [nixos-rebuild args...]
#   Defaults to the active local flake and records Prometheus textfile metrics.

set -euo pipefail

OUTFILE="/var/lib/node_exporter/textfile_collector/nix-rebuild.prom"

# Use the nixos-rebuild from the running system to avoid sudo PATH issues.
NIXOS_REBUILD=/run/current-system/sw/bin/nixos-rebuild
if [[ -n "${NIXOS_CONFIG_REPO:-}" ]]; then
  repo_dir="$NIXOS_CONFIG_REPO"
elif repo_dir="$(git rev-parse --show-toplevel 2>/dev/null)" && [[ -f "$repo_dir/flake.nix" ]]; then
  :
elif [[ -f "$HOME/dev/nixos-config/flake.nix" ]]; then
  repo_dir="$HOME/dev/nixos-config"
elif [[ -f /etc/nixos/flake.nix ]]; then
  repo_dir=/etc/nixos
else
  repo_dir="$PWD"
fi

usage() {
  cat <<'EOF'
Usage: rebuild [OPTIONS] VERB [NIXOS_REBUILD_ARGS...]

Verbs:
  switch        Build and activate now.
  boot          Build and make active on next boot.
  test          Activate without adding a bootloader entry.
  dry-activate  Build and show activation actions without applying them.
  build         Build only.

Options:
  --dev          Override selected flake inputs with matching $HOME/dev clones.
  --pull         Fast-forward the active repo from origin/main before rebuilding.
  --allow-dirty  Allow --pull with local changes.
  -h, --help     Show this help.
EOF
}

DEV_OVERRIDES=()
ARGS=()
PULL=0
ALLOW_DIRTY=0
for arg in "$@"; do
  case "$arg" in
    --dev)
      for spec in "hypr-config:hyprland-config" "hyprspace:hyprspace" "hyprchroma:hyprchroma" "hypr-canvas:hypr-canvas"; do
        input="${spec%%:*}"
        repo="${spec#*:}"
        if [[ -d "$HOME/dev/$repo/.git" || -f "$HOME/dev/$repo/.git" ]]; then
          echo "rebuild [dev]: redirecting input '$input' to local clone $HOME/dev/$repo"
          DEV_OVERRIDES+=("--override-input" "$input" "git+file://$HOME/dev/$repo")
        fi
      done
      ;;
    --pull)
      PULL=1
      ;;
    --allow-dirty)
      ALLOW_DIRTY=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      ARGS+=("$arg")
      ;;
  esac
done
set -- "${ARGS[@]}"

verb="${1:-}"
case "$verb" in
  switch|boot|test|dry-activate|build)
    ;;
  "")
    usage >&2
    exit 2
    ;;
  *)
    echo "rebuild: unknown verb '$verb'" >&2
    usage >&2
    exit 2
    ;;
esac

if [[ "$PULL" -eq 1 ]]; then
  if [[ ! -d "$repo_dir/.git" && ! -f "$repo_dir/.git" ]]; then
    echo "rebuild: --pull requires a git checkout: $repo_dir" >&2
    exit 2
  fi

  branch="$(git -C "$repo_dir" branch --show-current)"
  if [[ "$branch" != "main" ]]; then
    echo "rebuild: --pull is only allowed on main, current branch is '$branch'" >&2
    exit 2
  fi

  if [[ "$ALLOW_DIRTY" -eq 0 && -n "$(git -C "$repo_dir" status --porcelain)" ]]; then
    echo "rebuild: refusing --pull with local changes; pass --allow-dirty to override" >&2
    exit 2
  fi

  git -C "$repo_dir" fetch origin main
  git -C "$repo_dir" merge --ff-only origin/main
fi

if [[ -d "$repo_dir/.git" || -f "$repo_dir/.git" ]]; then
  FLAKE_REF="${FLAKE_REF:-git+file://${repo_dir}#legion}"
else
  FLAKE_REF="${FLAKE_REF:-${repo_dir}#legion}"
fi

start_ns=$(date +%s%N)
start_ts=$(date +%s)

# Run rebuild — allow failure so we can still record the exit code.
# Pass NIXOS_CONFIG_REPO into sudo environment and enable --impure so flake evaluation
# can dynamically resolve locality.repoCheckout via builtins.getEnv.
set +e
sudo NIXOS_CONFIG_REPO="$repo_dir" "$NIXOS_REBUILD" --impure --flake "$FLAKE_REF" "${DEV_OVERRIDES[@]}" "$@"
exit_code=$?
set -e

end_ns=$(date +%s%N)
duration_ms=$(( (end_ns - start_ns) / 1000000 ))
success=$([ "$exit_code" -eq 0 ] && echo 1 || echo 0)

# Write atomically. The textfile_collector dir is owned by tco (see observability.nix
# tmpfiles rule) so no sudo is needed here — and node_exporter reads 644 files fine.
TMPFILE=$(mktemp /tmp/nix-rebuild.prom.XXXXXX)
cat > "$TMPFILE" << EOF
# HELP nix_rebuild_duration_ms Duration of the last nixos-rebuild in milliseconds
# TYPE nix_rebuild_duration_ms gauge
nix_rebuild_duration_ms ${duration_ms}

# HELP nix_rebuild_timestamp_seconds Unix timestamp of the last nixos-rebuild
# TYPE nix_rebuild_timestamp_seconds gauge
nix_rebuild_timestamp_seconds ${start_ts}

# HELP nix_rebuild_success Whether the last nixos-rebuild succeeded (1) or failed (0)
# TYPE nix_rebuild_success gauge
nix_rebuild_success ${success}
EOF

install -m 644 "$TMPFILE" "$OUTFILE" && rm -f "$TMPFILE"

exit "$exit_code"
