#!/usr/bin/env bash
# Compile SCSS sources into a preview directory.
# In production, Nix/Home Manager generates CSS during the build.
#
# Usage :
#   scss-compile
#   scss-compile /tmp/scss-preview
#   SASS=dart-sass scss-compile
#
# Requirement: dart-sass (pkgs.dart-sass in home.nix)
# Without a rebuild: nix shell nixpkgs#dart-sass -c scss-compile

set -euo pipefail

repo_dir="${REPO_DIR:-$(git -C "$(dirname "$0")" rev-parse --show-toplevel 2>/dev/null || pwd)}"
sass_bin="${SASS:-sass}"
out_dir="${1:-${TMPDIR:-/tmp}/scss-compile}"

if ! command -v "$sass_bin" >/dev/null 2>&1; then
  echo "scss-compile: dart-sass not found" >&2
  echo "  after rebuild     : sass is available directly" >&2
  echo "  without rebuild   : nix shell nixpkgs#dart-sass -c scss-compile" >&2
  exit 1
fi

compile() {
  local src="$1" dst="$2"
  echo "scss-compile: $src → $dst"
  mkdir -p "$(dirname "$dst")"
  "$sass_bin" \
    --no-source-map \
    --no-charset \
    --style=expanded \
    "$src" "$dst"
}

compile \
  "${repo_dir}/config/hypr/waybar/style.scss" \
  "${out_dir}/waybar/style.css"

compile \
  "${repo_dir}/config/grafana/theme/aquamarine.scss" \
  "${out_dir}/grafana/aquamarine.css"

echo "scss-compile: OK"
echo "  → ${out_dir}/waybar/style.css"
echo "  → ${out_dir}/grafana/aquamarine.css"
