#!/usr/bin/env bash
set -euo pipefail

GAP_HELPER="/etc/nixos/config/bin/hypr-gap-state.sh"
# shellcheck source=/etc/nixos/config/bin/hypr-gap-state.sh
source "$GAP_HELPER"

REPO_LAUNCHER="/etc/nixos/config/conky/start_edex_conky_compact.sh"
USER_LAUNCHER="${XDG_CONFIG_HOME:-$HOME/.config}/conky/start_edex_conky_compact.sh"
CONKY_LAUNCHER="$REPO_LAUNCHER"
STATE_FILE="${XDG_RUNTIME_DIR:-/tmp}/conky-left-gap.base"
PANEL_WIDTH=296
LEFT_PANEL_MARGIN=8
RIGHT_PANEL_MARGIN=28

apply_conky_workspace_gaps() {
  local workspace="$1"
  local gaps_in="$2"
  local gaps_out="$3"
  local top right bottom left _

  read -r top right bottom left _ <<<"$gaps_out"
  top=${top:-16}
  right=${right:-16}
  bottom=${bottom:-16}
  left=${left:-16}

  local new_left=$((left + PANEL_WIDTH + LEFT_PANEL_MARGIN))
  local new_right=$((right + PANEL_WIDTH + RIGHT_PANEL_MARGIN))
  local new_gaps_out="${top} ${new_right} ${bottom} ${new_left}"

  hypr_apply_workspace_gaps "$workspace" "$gaps_in" "$new_gaps_out"
}

if pgrep -f 'conky -q -c.*conky-left' >/dev/null 2>&1 || \
   pgrep -f 'conky -q -c.*conky-right' >/dev/null 2>&1 || \
   pgrep -f 'conky .*system_panel' >/dev/null 2>&1; then
  # Kill all conky variants
  pkill -f 'conky -q -c.*conky-left' >/dev/null 2>&1 || true
  pkill -f 'conky -q -c.*conky-right' >/dev/null 2>&1 || true
  pkill -f 'conky -q -c.*conky\.txt' >/dev/null 2>&1 || true
  pkill -f 'conky .*system_panel' >/dev/null 2>&1 || true
  pkill -f 'conky .*network_panel' >/dev/null 2>&1 || true
  
  hypr_restore_workspace_state "$STATE_FILE" "$(hypr_get_global_gap_fallback "general:gaps_out" "16 16 16 16")"
  exit 0
fi

if [[ ! -r "$CONKY_LAUNCHER" ]]; then
  CONKY_LAUNCHER="$USER_LAUNCHER"
fi

if [[ ! -r "$CONKY_LAUNCHER" ]]; then
  echo "Conky launcher not found: $CONKY_LAUNCHER" >&2
  exit 1
fi

# Conky, Rofi sidebar and Hyprspace Overview are mutually exclusive.
pkill -x rofi >/dev/null 2>&1 || true
hyprctl dispatch overview:close all >/dev/null 2>&1 || true

mapfile -t TARGET_WORKSPACES < <(hypr_list_target_workspaces)
if [[ ${#TARGET_WORKSPACES[@]} -eq 0 ]]; then
  ACTIVE_WS="$(hyprctl activeworkspace -j | jq -r '.name // (.id | tostring)')"
  TARGET_WORKSPACES=("$ACTIVE_WS")
fi

hypr_capture_workspace_state "$STATE_FILE" "${TARGET_WORKSPACES[@]}"

for workspace in "${TARGET_WORKSPACES[@]}"; do
  gaps_in="$(hypr_get_workspace_gaps "$workspace" in)"
  gaps_out="$(hypr_get_workspace_gaps "$workspace" out)"
  if ! apply_conky_workspace_gaps "$workspace" "$gaps_in" "$gaps_out"; then
    hypr_restore_workspace_state "$STATE_FILE" "$(hypr_get_global_gap_fallback "general:gaps_out" "16 16 16 16")"
    exit 1
  fi
done

if ! bash "$CONKY_LAUNCHER"; then
  hypr_restore_workspace_state "$STATE_FILE" "$(hypr_get_global_gap_fallback "general:gaps_out" "16 16 16 16")"
  exit 1
fi

(
  while pgrep -f 'conky -q -c.*conky-left' >/dev/null 2>&1 || \
        pgrep -f 'conky -q -c.*conky-right' >/dev/null 2>&1 || \
        pgrep -f 'conky -q -c.*conky\.txt' >/dev/null 2>&1; do
    sleep 1
  done

  hypr_restore_workspace_state "$STATE_FILE" "$(hypr_get_global_gap_fallback "general:gaps_out" "16 16 16 16")"
) >/dev/null 2>&1 &
