#!/usr/bin/env bash

# Utilise pgrep -f pour être sûr de matcher le script bash
if pgrep -f "legion-pulse" > /dev/null
then
    pkill -f "legion-pulse"
    brightnessctl -d "platform::kbd_backlight" set 2
else
    # Use the Home Manager-installed entrypoint instead of the repo path.
    bash "$HOME/.local/bin/legion-pulse" &
fi
