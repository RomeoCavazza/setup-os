#!/usr/bin/env bash

set -euo pipefail

OUTFILE="/var/lib/node_exporter/textfile_collector/hyprland.prom"
TMPFILE="${OUTFILE}.tmp"

if [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
  USER_UID=$(id -u)
  HYPR_DIR="/run/user/${USER_UID}/hypr"
  if [[ -d "$HYPR_DIR" ]]; then
    # shellcheck disable=SC2012
    SIG=$(find "$HYPR_DIR" -maxdepth 1 -mindepth 1 -printf '%P\n' | head -n 1 || true)
    if [[ -n "$SIG" ]]; then
      export HYPRLAND_INSTANCE_SIGNATURE="$SIG"
    fi
  fi
fi

if monitors_json=$(hyprctl monitors -j 2>/dev/null); then
  active_ws=$(echo "$monitors_json" | jq -r '.[0].activeWorkspace.id')
  fullscreen=$(echo "$monitors_json" | jq -r '.[0].hasfullscreen | if . then 1 else 0 end')
else
  active_ws="1"; fullscreen="0"
fi

if clients_json=$(hyprctl clients -j 2>/dev/null); then
  total_windows=$(echo "$clients_json" | jq '. | length')
  floating_windows=$(echo "$clients_json" | jq '[.[] | select(.floating == true)] | length')
  active_client=$(echo "$clients_json" | jq -r '.[] | select(.focusHistoryID == 0) | "\(.class)@\(.title)"' || echo "none@none")
else
  total_windows="0"; floating_windows="0"; active_client="none@none"
fi

if workspaces_json=$(hyprctl workspaces -j 2>/dev/null); then
  workspaces_count=$(echo "$workspaces_json" | jq '. | length')
else
  workspaces_count="0"
fi

win_class="${active_client%%@*}"
win_title="${active_client#*@}"
win_class="${win_class:-none}"
win_title="${win_title:-none}"

win_class=${win_class//\\/\\\\}
win_class=${win_class//\"/\\\"}
win_title=${win_title//\\/\\\\}
win_title=${win_title//\"/\\\"}

cat > "$TMPFILE" << EOF
# HELP hypr_active_workspace_id Current active workspace ID
# TYPE hypr_active_workspace_id gauge
hypr_active_workspace_id ${active_ws}

# HELP hypr_windows_total Total number of windows open in Hyprland
# TYPE hypr_windows_total gauge
hypr_windows_total ${total_windows}

# HELP hypr_floating_windows_total Total number of floating windows
# TYPE hypr_floating_windows_total gauge
hypr_floating_windows_total ${floating_windows}

# HELP hypr_fullscreen_active Is there a fullscreen window active (0/1)
# TYPE hypr_fullscreen_active gauge
hypr_fullscreen_active ${fullscreen}

# HELP hypr_workspaces_total Total number of active workspaces
# TYPE hypr_workspaces_total gauge
hypr_workspaces_total ${workspaces_count}

# HELP hypr_active_window Info about the currently focused window
# TYPE hypr_active_window gauge
hypr_active_window{class="${win_class}",title="${win_title}"} 1
EOF

mv "$TMPFILE" "$OUTFILE"
