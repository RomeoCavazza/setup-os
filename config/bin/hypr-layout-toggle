#!/usr/bin/env bash

# ==============================================================================
# HYPR-LAYOUT-TOGGLE (simple, decoupled from every plugin)
# ==============================================================================

TARGET_W=939
TARGET_H=1136

WS=$(hyprctl activeworkspace -j | jq '.id')
WINDOWS=$(hyprctl clients -j | jq -r ".[] | select(.workspace.id == $WS) | .address")

# 1. DETECT STATE
# If at least one window floats on this workspace, reset everything.
if hyprctl clients -j | jq -e ".[] | select(.workspace.id == $WS and .floating == true)" >/dev/null; then
  # 2. RESET (TILE ALL)
  cmds=""
  for addr in $WINDOWS; do
    cmds+="dispatch settiled address:$addr; "
  done
  hyprctl --batch "$cmds"
else
  # 3. CANVAS (FLOAT ALL + APPLY REFERENCE SIZE)
  cmds=""
  for addr in $WINDOWS; do
    cmds+="dispatch setfloating address:$addr; "
    cmds+="dispatch resizewindowpixel exact $TARGET_W $TARGET_H,address:$addr; "
  done
  hyprctl --batch "$cmds"
fi
