#!/usr/bin/env bash

set -euo pipefail

OUTFILE="/var/lib/node_exporter/textfile_collector/nix-store.prom"
TMPFILE="${OUTFILE}.tmp"

df_stats=$(df --output=used,avail,size -B1 /nix/store 2>/dev/null \
  | awk 'NR == 2 { print $1, $2, $3 }' || echo "0 0 0")
read -r store_bytes store_available_bytes store_capacity_bytes <<< "${df_stats:-0 0 0}"
store_usage_ratio=$(awk -v used="${store_bytes:-0}" -v total="${store_capacity_bytes:-0}" \
  'BEGIN { if (total > 0) printf "%.6f", used / total; else print 0 }')

store_paths=$(find /nix/store -mindepth 1 -maxdepth 1 -printf '.' 2>/dev/null | wc -c || echo 0)

closure_paths=$(nix-store -q --requisites /run/current-system 2>/dev/null | wc -l || echo 0)
closure_bytes=$(nix path-info -rS /run/current-system 2>/dev/null \
  | awk '{sum += $2} END { print (sum ? sum : 0) }')
top_closures=$(nix path-info -rS /run/current-system 2>/dev/null \
  | awk 'NF >= 2 { print $1, $2 }' \
  | sort -k2,2nr 2>/dev/null \
  | head -10 || true)

generations=$(nix-env --list-generations -p /nix/var/nix/profiles/system 2>/dev/null || true)
current_gen=$(printf '%s\n' "$generations" \
  | awk '/\(current\)/ { print $1; found = 1; exit } END { if (!found) print 0 }')
generations_count=$(printf '%s\n' "$generations" \
  | awk 'NF > 0 { c++ } END { print (c ? c : 0) }')

repo_dir="${REPO_DIR:-${NIXOS_CONFIG_REPO:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}}"
flake_lock="${repo_dir}/flake.lock"
if [[ -f "$flake_lock" ]]; then
  lock_age=$(( $(date +%s) - $(stat -c %Y "$flake_lock") ))
else
  lock_age=0
fi

pressure_cpu_avg10=$(awk '/^some / { for (i = 1; i <= NF; i++) if ($i ~ /^avg10=/) { sub("avg10=", "", $i); print $i; exit } }' /proc/pressure/cpu 2>/dev/null || echo 0)
pressure_io_some_avg10=$(awk '/^some / { for (i = 1; i <= NF; i++) if ($i ~ /^avg10=/) { sub("avg10=", "", $i); print $i; exit } }' /proc/pressure/io 2>/dev/null || echo 0)
pressure_mem_some_avg10=$(awk '/^some / { for (i = 1; i <= NF; i++) if ($i ~ /^avg10=/) { sub("avg10=", "", $i); print $i; exit } }' /proc/pressure/memory 2>/dev/null || echo 0)

cat > "$TMPFILE" << EOF
# HELP nix_store_bytes Nix store used space in bytes (from df)
# TYPE nix_store_bytes gauge
nix_store_bytes ${store_bytes}

# HELP nix_store_available_bytes Nix store filesystem available space in bytes (from df)
# TYPE nix_store_available_bytes gauge
nix_store_available_bytes ${store_available_bytes}

# HELP nix_store_capacity_bytes Nix store filesystem capacity in bytes (from df)
# TYPE nix_store_capacity_bytes gauge
nix_store_capacity_bytes ${store_capacity_bytes}

# HELP nix_store_usage_ratio Nix store filesystem usage ratio from 0 to 1
# TYPE nix_store_usage_ratio gauge
nix_store_usage_ratio ${store_usage_ratio}

# HELP nix_store_paths Total number of paths currently in the Nix store
# TYPE nix_store_paths gauge
nix_store_paths ${store_paths}

# HELP nix_closure_paths Number of store paths in the running system closure
# TYPE nix_closure_paths gauge
nix_closure_paths ${closure_paths}

# HELP nix_closure_bytes Cumulative size of the running system closure in bytes
# TYPE nix_closure_bytes gauge
nix_closure_bytes ${closure_bytes}

# HELP nix_closure_top_bytes Top store paths by size inside the running system closure
# TYPE nix_closure_top_bytes gauge
EOF

rank=0
while read -r path bytes; do
  [[ -n "${path:-}" && -n "${bytes:-}" ]] || continue
  rank=$((rank + 1))
  label=$(basename "$path")
  label=${label//\\/\\\\}
  label=${label//\"/\\\"}
  printf 'nix_closure_top_bytes{rank="%d",path="%s"} %s\n' "$rank" "$label" "$bytes" >> "$TMPFILE"
done <<< "$top_closures"

cat >> "$TMPFILE" << EOF

# HELP nix_generation Current NixOS generation number
# TYPE nix_generation gauge
nix_generation ${current_gen}

# HELP nix_generations_count Number of retained NixOS generations
# TYPE nix_generations_count gauge
nix_generations_count ${generations_count}

# HELP nix_flake_lock_age_seconds Seconds since flake.lock was last modified
# TYPE nix_flake_lock_age_seconds gauge
nix_flake_lock_age_seconds ${lock_age}

# HELP nix_pressure_cpu_avg10 CPU PSI avg10 from /proc/pressure/cpu
# TYPE nix_pressure_cpu_avg10 gauge
nix_pressure_cpu_avg10 ${pressure_cpu_avg10}

# HELP nix_pressure_io_some_avg10 IO PSI some avg10 from /proc/pressure/io
# TYPE nix_pressure_io_some_avg10 gauge
nix_pressure_io_some_avg10 ${pressure_io_some_avg10}

# HELP nix_pressure_mem_some_avg10 Memory PSI some avg10 from /proc/pressure/memory
# TYPE nix_pressure_mem_some_avg10 gauge
nix_pressure_mem_some_avg10 ${pressure_mem_some_avg10}
EOF

nix path-info -r --json /run/current-system 2>/dev/null \
  | "${repo_dir}/config/bin/nix-flamegraph.py" >> "$TMPFILE" || true

mv "$TMPFILE" "$OUTFILE"
